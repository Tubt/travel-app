{
  "name": "travel-app",
  "version": "1.0.0",
  "description": "Travel application with Cypress testing framework",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "cd test && npm run cypress:run",
    "test:open": "cd test && npm run cypress:open",
    "test:checklist": "cd test && npm run test:checklist",
    "test:integrated": "cd test && npm run test:checklist-integrated",
    "test:smoke": "cd test && npm run test:checklist-smoke",
    "test:tag": "cd test && npm run test:tag",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:up-d": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:test": "docker compose up --build",
    "docker:test-integrated": "docker compose -f docker-compose.yml -f docker-compose.integrated.yml up --build",
    "docker:test-smoke": "docker compose -f docker-compose.yml -f docker-compose.smoke.yml up --build",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev-d": "docker compose -f docker-compose.dev.yml up -d",
    "docker:test-dev": "docker compose -f docker-compose.dev.yml up --build cypress-dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "@types/react-router-dom": "^5.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^7.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
